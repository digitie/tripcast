# tripcast 환경변수 예시
# `cp .env.example .env` 후 값 수정

# DB
POSTGRES_USER=tripcast
POSTGRES_PASSWORD=tripcast
POSTGRES_DB=tripcast
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8000
JWT_SECRET=please-change-this-to-a-long-random-string
CORS_ORIGINS=http://localhost:5173

# Frontend
FRONTEND_PORT=5173
VITE_API_BASE=http://localhost:8000

# Airflow
AIRFLOW_PORT=8080
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_SECRET=please-change-me

# 외부 API
# data.go.kr 에서 발급받은 인증키 (URL Decoded 값 사용)
DATA_GO_KR_KEY=
# 텔레그램 봇 토큰 (@BotFather)
TELEGRAM_BOT_TOKEN=

# 시군구 행정경계 SHP(zip) 직링크. data.go.kr 등에서 받은 URL.
# 비워두면 region_update DAG 는 아무 작업도 하지 않는다.
REGION_SHP_URL=
# 원본 좌표계 SRID (행정안전부 기본 5179, 국토지리정보원 dataset 은 5186 인 경우도 있음)
REGION_SHP_SRID=5179
